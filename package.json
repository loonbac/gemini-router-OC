{
  "name": "gemini-router",
  "version": "1.0.0",
  "description": "Servidor HTTP compatible con OpenAI que puentea a Gemini CLI. Plugin para OpenCode.",
  "license": "PolyForm-Noncommercial-1.0.0",
  "author": "Loonbac <https://github.com/loonbac>",
  "repository": {
    "type": "git",
    "url": "https://github.com/loonbac/gemini-router-OC.git"
  },
  "type": "module",
  "main": "dist/plugin.js",
  "exports": {
    ".": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js"
    }
  },
  "bin": {
    "gemini-router": "./dist/server.js",
    "gemini-router-service": "./dist/service/index.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.build.json && node dist/post-build.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "hono": "^4.0.0",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "supertest": "^7.2.2",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
